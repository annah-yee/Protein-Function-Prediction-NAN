#!/bin/bash --login
##SBATCH -C [agx|agg|nal|neh|nfh|nif|nvf|nel]
#SBATCH --nodes=1
#SBATCH --ntasks-per-node=1
#SBATCH --cpus-per-task=16
#SBATCH --mem=16G
